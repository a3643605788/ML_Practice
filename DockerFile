# 1. 選⼀個 Python 基底映像
FROM python:3.12-slim
# 2. 在容器裡建⽴⼯作⽬錄
WORKDIR /app
# 3. 先複製 requirements，安裝套件
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# 4. 再把整個專案複製進去
COPY . .
# 5. 對外開放 8000 port（FastAPI / Uvicorn 預設）
EXPOSE 8000
# 6. 啟動指令：跑 FastAPI
#    housePrice_api.py 裡⾯有 app = FastAPI()
CMD ["uvicorn", "housePrice_api:app", "--host", "0.0.0.0", "--port", "8000"]

# 建立docker image語法:docker build -t houseprice_api:latest .
# 用image建立並執行container:docker run -d -p 8000:8000 --name houseprice_api houseprice_api:latest